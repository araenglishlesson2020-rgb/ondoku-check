 "od_l82": [
  {
   "en": "Morgan has wanted a pet for a long time.",
   "f": "audio/jenny/od_l82/0.mp3",
   "s": "audio/jenny/od_l82/0s.mp3"
  },
  {
   "en": "One morning, there was a small box on the table with her name on it.",
   "f": "audio/jenny/od_l82/1.mp3",
   "s": "audio/jenny/od_l82/1s.mp3"
  },
  {
   "en": "Inside the box, there was a bunch of dirt.",
   "f": "audio/jenny/od_l82/2.mp3",
   "s": "audio/jenny/od_l82/2s.mp3"
  },
  {
   "en": "Under the dirt was her new pet, a worm!",
   "f": "audio/jenny/od_l82/3.mp3",
   "s": "audio/jenny/od_l82/3s.mp3"
  },
  {
   "en": "Morgan was sad. She thinks a worm is the worst pet in the world.",
   "f": "audio/jenny/od_l82/4.mp3",
   "s": "audio/jenny/od_l82/4s.mp3"
  },
  {
   "en": "She wanted a dog or cat or even a hamster, not a squirmy worm!",
   "f": "audio/jenny/od_l82/5.mp3",
   "s": "audio/jenny/od_l82/5s.mp3"
  },
  {
   "en": "What were her mom and dad thinking? This pet will not work.",
   "f": "audio/jenny/od_l82/6.mp3",
   "s": "audio/jenny/od_l82/6s.mp3"
  },
  {
   "en": "She started to cry.",
   "f": "audio/jenny/od_l82/7.mp3",
   "s": "audio/jenny/od_l82/7s.mp3"
  },
  {
   "en": "Just then, mom and dad came in and said, \"We got you! It was a joke!\"",
   "f": "audio/jenny/od_l82/8.mp3",
   "s": "audio/jenny/od_l82/8s.mp3"
  },
  {
   "en": "\"We are going to the pet shop!\"",
   "f": "audio/jenny/od_l82/9.mp3",
   "s": "audio/jenny/od_l82/9s.mp3"
  },
  {
   "en": "Morgan was so happy. She wiped her face and gave mom and dad a hug.",
   "f": "audio/jenny/od_l82/10.mp3",
   "s": "audio/jenny/od_l82/10s.mp3"
  },
  {
   "en": "She was going to get the best pet ever!",
   "f": "audio/jenny/od_l82/11.mp3",
   "s": "audio/jenny/od_l82/11s.mp3"
  }
 ],
