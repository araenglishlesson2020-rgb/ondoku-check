{
 "od_l81": [
  {
   "en": "Irma the turtle loved to surf.",
   "f": "audio/od_l81/0.m4a?v=2"
  },
  {
   "en": "Her mother, Shirly, was the first girl surfer in their turtle village, and Irma wanted to be just like her.",
   "f": "audio/od_l81/1.m4a?v=2"
  },
  {
   "en": "Every morning Irma would rush to the shoreline.",
   "f": "audio/od_l81/2.m4a?v=2"
  },
  {
   "en": "When she was surfing, Irma would do flips and turns.",
   "f": "audio/od_l81/3.m4a?v=2"
  },
  {
   "en": "She would twirl like a twister.",
   "f": "audio/od_l81/4.m4a?v=2"
  },
  {
   "en": "All the other animals were shocked that a girl turtle could surf so well!",
   "f": "audio/od_l81/5.m4a?v=2"
  },
  {
   "en": "Irma would just yell, \"A girl can do anything!\" just like her mother told her.",
   "f": "audio/od_l81/6.m4a?v=2"
  },
  {
   "en": "Irma would surf until sunset.",
   "f": "audio/od_l81/7.m4a?v=2"
  },
  {
   "en": "When the sun was no longer in the sky, she would skip back home.",
   "f": "audio/od_l81/8.m4a?v=2"
  },
  {
   "en": "Once she was home, she would curl up in her turtle bed and relax.",
   "f": "audio/od_l81/9.m4a?v=2"
  }
 ],
